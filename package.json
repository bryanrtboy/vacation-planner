{
  "name": "artist-travel-finder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1",
    "dev:turbo": "next dev --turbo --hostname 127.0.0.1",
    "next:build": "next build",
    "build": "opennextjs-cloudflare build",
    "cf:build": "npm run build",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "deploy": "npm run build && npm run cf:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "formdata-node": "^6.0.3",
    "glob": "^12.0.0",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^22.19.21",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "wrangler": "^4.99.0"
  }
}
